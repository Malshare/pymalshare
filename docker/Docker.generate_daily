FROM python:3.14

WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
        libmariadb-dev build-essential \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir mariadb
COPY lib /app/lib
RUN mkdir /daily
COPY generate_daily.py /app/
CMD ["python3", "-u", "generate_daily.py"]
